prompt() {
    PS1=$(printf "%*s\r%s " "$(tput cols)" '\e[100;30m \A' '\e[100;30m \A 薰ｱ \u@\h 薰ｱ \w \e[0;90;47m薰ｰ \e[30m%\e[37m薰ｰ\e[m薰ｰ')
}
PROMPT_COMMAND=prompt
